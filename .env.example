# Supabase (kopieer naar .env.local en vul in)
# Aanmaak: https://supabase.com/dashboard → New project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key
# Alleen voor beheer: accounts verwijderen (Settings → API → service_role key). NOOIT in de browser gebruiken.
# SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# Optioneel: debiteurfacturen per e-mail (Resend — https://resend.com)
# RESEND_API_KEY=re_...
# EMAIL_FROM="Facturen <facturen@jouwdomein.nl>"
# Publieke URL van de site (logo in PDF bij e-mail); op Vercel vaak automatisch
# NEXT_PUBLIC_SITE_URL=https://jouwdomein.nl
